OPENAI_API_KEY=your_openai_api_key_here
VOYAGE_API_KEY=your_voyage_api_key_here
VOYAGE_MAX_RETRIES=3

# 必須: 生成・要約・judge に使う OpenAI モデル名（例: gpt-5.1-mini 等。空欄だと生成が失敗する）
LLM_MODEL=
CONDENSE_MODEL=
JUDGE_MODEL=
# 任意: ローカルLLM切り替え（generation/のcondense・generate_answer_streamのみ対象。judgeは常にOpenAI固定）
# openai（既定・本番）| ollama（ローカル開発用。Qwen3.5等をOllama経由で使用。Ollama v0.13.3以降の/v1/responses対応が前提）
# LLM_PROVIDER=openai
# LLM_PROVIDER=ollama の場合、LLM_MODEL/CONDENSE_MODEL には Ollama のモデルタグを指定（例: qwen3.5:9b。`ollama list`で確認）
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=ollama
# 必須: 埋め込みに使う Voyage モデル名（例: voyage-4-lite。空欄・不正値だと全チャットが 500 になる）
EMBED_MODEL=

# 任意: Langfuse（未設定なら計装はno-opになり、アプリ・デモ・evalは動作する）
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# 開発/デモ用DBへの接続情報。自動テストは rag_test を使う（make test が DATABASE_URL を直接上書きして切り替える。docs/architecture.md §9）
# DB_HOSTの既定値localhostはネイティブ実行向け。docker-compose経由ではapi/ingest_workerサービスがDB_HOST=db（サービス名）に上書きする
DB_HOST=db
DB_PORT=5432
DB_USER=rag_user
DB_PASS=rag_pass
DB_NAME=rag_dev
# 明示的に指定するとDB_*より優先される（既定は空・通常は指定不要。Makefile/CIのDATABASE_URL直接上書きが該当）
# DATABASE_URL=
# 取り込み対象ディレクトリ。個人の文書に差し替え可能（make demoは常にseed/corpusを使うため影響されない）
CORPUS_DIR=seed/corpus

# 増分再取り込み設定（すべて任意。既定値は core/config.py 参照）
# INGEST_DELETE_GUARD_RATIO=0.5
# INGEST_ADVISORY_LOCK_KEY=727110001
# INGEST_STALE_RUNNING_SEC=600
# INGEST_STATS_FLUSH_EVERY=10
# INGEST_EMBED_BATCH_SIZE=64
# INGEST_EMBED_MIN_INTERVAL_SEC=21.0
# INGEST_TRIGGER=cli
# FORCE_DELETE=0

# Retrieval設定（すべて任意。既定値は core/config.py 参照）
# RETRIEVAL_STRATEGY=hybrid_rerank
# CANDIDATE_K=50
# RRF_K=60
# FUSE_K=40
# RERANK_TOP_K=8

# Chat & Streaming設定（すべて任意。既定値は core/config.py 参照）
# CONDENSE_HISTORY_TURNS=5
# CHAT_HISTORY_TOKEN_BUDGET=1000
# SSE_KEEPALIVE_SEC=15
# TITLE_MAX_CHARS=40

# Routing設定（M7。任意。既定値は core/config.py 参照）
# grade の grounded/direct 分岐閾値。ADR 0001（docs/adr/0001_m7_theta_threshold.md）でキャリブレーション決定した値が既定値
# ROUTING_THETA=0.56

# Google Drive設定（M9・任意。DRIVE_FOLDER_ID/DRIVE_SERVICE_ACCOUNT_FILEが空の場合Drive取り込み機能は無効。
# 手順はREADMEの「Google Driveからの取り込み」セクションを参照）
# DRIVE_FOLDER_ID=
# DRIVE_SERVICE_ACCOUNT_FILE=
# REDIS_URL=redis://localhost:6379/0
# INGEST_GDRIVE_JOB_MAX_TRIES=3
# INGEST_GDRIVE_JOB_TIMEOUT_SEC=3600
# DRIVE_API_MAX_RETRIES=5

# Evaluation設定（すべて任意。既定値は core/config.py 参照）
# JUDGE_TEMPERATURE=0.0
# EVAL_GEN_TEMPERATURE=0.0
# EVAL_GEN_MAX_TOKENS=1024
# EVAL_TOP_K=12
# EVAL_EF_SEARCH=100
# EVAL_JUDGE_SAMPLES=1
# EVAL_DATASET_PATH=evals/dataset/m3_golden.jsonl
# EVAL_RETRIEVAL_CACHE_PATH=evals/cache/m3_retrieval.json
